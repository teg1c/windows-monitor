type Event struct {
	Source    string
	Body      string
	ImagePath string
	Hash      string
	Distance  int
	CreatedAt time.Time
}

type Notifier interface {
	Name() string
	Notify(ctx context.Context, title string, body string, event *Event) error
}

func BuildAll(configs []config.NotifierConfig) ([]Notifier, error) {
	var notifiers []Notifier
	for _, cfg := range configs {
		if !cfg.Enabled {
			continue
		}
		notifier, err := Build(cfg)
		if err != nil {
			return nil, err
		}
		notifiers = append(notifiers, notifier)
	}
	return notifiers, nil
}

func Build(cfg config.NotifierConfig) (Notifier, error) {
	switch strings.ToLower(cfg.Type) {
	case "console":
		return consoleNotifier{name: nameOr(cfg.Name, "console")}, nil
	case "webhook":
		if cfg.URL == "" {
			return nil, fmt.Errorf("webhook url is required")
		}
		return webhookNotifier{name: nameOr(cfg.Name, "webhook"), url: cfg.URL, headers: cfg.Headers}, nil
	case "serverchan":
		if cfg.SendKey == "" {
			return nil, fmt.Errorf("serverchan send_key is required")
		}
		return serverChanNotifier{name: nameOr(cfg.Name, "serverchan"), sendKey: cfg.SendKey}, nil
	case "bark":
		if cfg.DeviceKey == "" {
			return nil, fmt.Errorf("bark device_key is required")
		}
		baseURL := cfg.BaseURL
		if baseURL == "" {
			baseURL = "https://api.day.app"
		}
		return barkNotifier{name: nameOr(cfg.Name, "bark"), baseURL: strings.TrimRight(baseURL, "/"), deviceKey: cfg.DeviceKey}, nil
	case "telegram":
		if cfg.BotToken == "" || cfg.ChatID == "" {
			return nil, fmt.Errorf("telegram bot_token and chat_id are required")
		}
		return telegramNotifier{name: nameOr(cfg.Name, "telegram"), botToken: cfg.BotToken, chatID: cfg.ChatID}, nil
	case "smtp":
		if cfg.Host == "" || cfg.From == "" || len(cfg.To) == 0 {
			return nil, fmt.Errorf("smtp host/from/to are required")
		}
		if cfg.Port == 0 {
			cfg.Port = 587
		}
		return smtpNotifier{name: nameOr(cfg.Name, "smtp"), cfg: cfg}, nil
	case "dingtalk":
		if cfg.WebhookURL == "" {
			return nil, fmt.Errorf("dingtalk webhook_url is required")
		}
		return dingtalkNotifier{name: nameOr(cfg.Name, "dingtalk"), webhookURL: cfg.WebhookURL}, nil
	case "feishu":
		if cfg.WebhookURL == "" {
			return nil, fmt.Errorf("feishu webhook_url is required")
		}
		return feishuNotifier{name: nameOr(cfg.Name, "feishu"), webhookURL: cfg.WebhookURL}, nil
	default:
		return nil, fmt.Errorf("unsupported notifier type: %s", cfg.Type)
	}
}

type consoleNotifier struct {
	name string
}

func (n consoleNotifier) Name() string { return n.name }

func (n consoleNotifier) Notify(ctx context.Context, title string, body string, event *Event) error {
	_, _ = ctx, event
	fmt.Printf("%s\n%s\n\n", title, body)
	return nil
}

type webhookNotifier struct {
	name    string
	url     string
	headers map[string]string
}

func (n webhookNotifier) Name() string { return n.name }

func (n webhookNotifier) Notify(ctx context.Context, title string, body string, event *Event) error {
	return postJSON(ctx, n.url, map[string]any{
		"title":      title,
		"body":       body,
		"source":     event.Source,
		"image_path": event.ImagePath,
		"hash":       event.Hash,
		"distance":   event.Distance,
		"created_at": event.CreatedAt.Format(time.RFC3339),
	}, n.headers)
}

type serverChanNotifier struct {
	name    string
	sendKey string
}

func (n serverChanNotifier) Name() string { return n.name }

func (n serverChanNotifier) Notify(ctx context.Context, title string, body string, event *Event) error {
	_ = event
	return postJSON(ctx, "https://sctapi.ftqq.com/"+url.PathEscape(n.sendKey)+".send", map[string]string{"title": title, "desp": body}, nil)
}

type barkNotifier struct {
	name      string
	baseURL   string
	deviceKey string
}

func (n barkNotifier) Name() string { return n.name }

func (n barkNotifier) Notify(ctx context.Context, title string, body string, event *Event) error {
	_ = event
	target := n.baseURL + "/" + url.PathEscape(n.deviceKey) + "/" + url.PathEscape(title) + "/" + url.PathEscape(body)
	req, err := http.NewRequestWithContext(ctx, http.MethodGet, target, nil)
	if err != nil {
		return err
	}
	resp, err := http.DefaultClient.Do(req)
	if err != nil {
		return err
	}
	defer resp.Body.Close()
	_, _ = io.Copy(io.Discard, resp.Body)
	if resp.StatusCode >= 300 {
		return fmt.Errorf("bark returned %s", resp.Status)
	}
	return nil
}

