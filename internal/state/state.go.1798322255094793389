package state

import (
	"encoding/json"
	"errors"
	"os"
	"path/filepath"
	"time"
)

type State struct {
	LastHash       string `json:"last_hash"`
	LastText       string `json:"last_text"`
	LastNotifiedAt int64  `json:"last_notified_at"`
	PendingHash    string `json:"pending_hash"`
	PendingCount   int    `json:"pending_count"`
}

func Load(path string) (*State, error) {
	data, err := os.ReadFile(path)
	if err != nil {
		if errors.Is(err, os.ErrNotExist) {
			return &State{}, nil
		}
		return nil, err
	}
	var state State
	if err := json.Unmarshal(data, &state); err != nil {
		return nil, err
	}
	return &state, nil
}

func (s *State) Save(path string) error {
	if err := os.MkdirAll(filepath.Dir(path), 0755); err != nil {
		return err
	}
	data, err := json.MarshalIndent(s, "", "  ")
	if err != nil {
		return err
	}
	return os.WriteFile(path, data, 0644)
}

func (s *State) CooldownPassed(seconds int) bool {
	if seconds <= 0 || s.LastNotifiedAt == 0 {
		return true
	}
	return time.Since(time.Unix(s.LastNotifiedAt, 0)) >= time.Duration(seconds)*time.Second
}

